generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum ProvedorAuth {
  EMAIL
  GOOGLE
}

enum TipoTransacao {
  RECEITA
  DESPESA
}

enum TipoRecurso {
  DINHEIRO
  VA
  VR
  VT
}

enum StatusMeta {
  ATIVA
  PAUSADA
  CONCLUIDA
  CANCELADA
}

enum TipoMeta {
  CURTO_PRAZO
  LONGO_PRAZO
}

enum TipoCategoria {
  RECEITA
  DESPESA
}

enum CategoriaDespesaViagem {
  TRANSPORTE
  HOSPEDAGEM
  ALIMENTACAO
  PASSEIOS
  COMPRAS
  OUTROS
}

enum Tema {
  CLARO
  ESCURO
}

enum AntecedenciaLembrete {
  NO_DIA
  UM_DIA
  TRES_DIAS
}

enum PapelGrupo {
  ADMIN
  MEMBRO
}

enum NivelFinanceiro {
  INICIANTE
  CONSCIENTE
  ESTRATEGISTA
  INVESTIDOR
}

/// Modo de uso do app (RF-103) — badges perfil.* no frontend
enum ModoUso {
  ESTAGIARIO
  CLT
  PJ
  PESSOA_FISICA
}

/// Prioridade opcional em metas / itens (badges prioridade.*)
enum Prioridade {
  ALTA
  MEDIA
  BAIXA
}

// ==========================================
// USUÁRIOS
// ==========================================

model Usuario {
  id           String       @id @default(cuid())
  nome         String       @db.VarChar(120)
  email        String       @unique @db.VarChar(180)
  senhaHash    String?      @map("senha_hash")
  urlAvatar    String?      @map("url_avatar")
  provedorAuth ProvedorAuth @default(EMAIL) @map("provedor_auth")
  googleId     String?      @unique @map("google_id")
  verificado   Boolean      @default(false)
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  configuracoes       ConfiguracaoUsuario?
  tokensRenovacao     TokenRenovacao[]
  transacoes          Transacao[]
  categorias          Categoria[]
  tags                Tag[]
  metas               Meta[]
  viagens             Viagem[]
  lembretes           Lembrete[]
  vendasVt            VendaVt[]
  usosVt              UsoVt[]
  sequencia           Sequencia?
  conquistasUsuario   ConquistaUsuario[]
  moedasFavoritas     MoedaFavorita[]
  desafiosMensais     DesafioMensal[]
  mensagensChat       MensagemChat[]
  historicoScore      HistoricoScore[]
  gruposCriados       Grupo[]              @relation("CriadorGrupo")
  membrosGrupo        MembroGrupo[]
  aportesGrupo        AporteMetaGrupo[]
  despesasViagemGrupo DespesaViagemGrupo[]
  mensagensChatGrupo  MensagemChatGrupo[]

  @@index([email])
  @@map("usuarios")
}

// ==========================================
// CONFIGURAÇÕES DO USUÁRIO
// ==========================================

model ConfiguracaoUsuario {
  id                   String   @id @default(cuid())
  usuarioId            String   @unique @map("usuario_id")
  valorSalario         Decimal  @default(0) @db.Decimal(12, 2) @map("valor_salario")
  diaSalario           Int      @default(5) @map("dia_salario")
  valorVa              Decimal  @default(0) @db.Decimal(12, 2) @map("valor_va")
  diaVa                Int      @default(5) @map("dia_va")
  valorVr              Decimal  @default(0) @db.Decimal(12, 2) @map("valor_vr")
  diaVr                Int      @default(5) @map("dia_vr")
  valorVt              Decimal  @default(0) @db.Decimal(12, 2) @map("valor_vt")
  diaVt                Int      @default(5) @map("dia_vt")
  diasIntervaloVendaVt Int      @default(30) @map("dias_intervalo_venda_vt")
  tema                 Tema     @default(CLARO)
  gamificacaoAtiva     Boolean  @default(true) @map("gamificacao_ativa")
  googleCalendarAtivo  Boolean  @default(false) @map("google_calendar_ativo")
  tokensGoogle         Json?    @map("tokens_google") // criptografado em repouso
  limiteGastos         Decimal? @db.Decimal(12, 2) @map("limite_gastos")
  modoUso              ModoUso  @default(CLT) @map("modo_uso")
  criadoEm             DateTime @default(now()) @map("criado_em")
  atualizadoEm         DateTime @updatedAt @map("atualizado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("configuracoes_usuario")
}

// ==========================================
// TOKENS DE RENOVAÇÃO
// ==========================================

model TokenRenovacao {
  id         String    @id @default(cuid())
  usuarioId  String    @map("usuario_id")
  token      String    @unique
  expiraEm   DateTime  @map("expira_em")
  revogado   Boolean   @default(false)
  criadoEm   DateTime  @default(now()) @map("criado_em")
  revogadoEm DateTime? @map("revogado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
  @@map("tokens_renovacao")
}

// ==========================================
// CATEGORIAS
// ==========================================

model Categoria {
  id        String        @id @default(cuid())
  nome      String        @db.VarChar(60)
  icone     String?       @db.VarChar(40)
  cor       String        @default("#7C3AED") @db.VarChar(7) // hex color (#RRGGBB)
  tipo      TipoCategoria
  padrao    Boolean       @default(false)
  usuarioId String?       @map("usuario_id")
  criadoEm  DateTime      @default(now()) @map("criado_em")

  usuario        Usuario?        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  transacoes     Transacao[]
  despesasViagem DespesaViagem[]

  @@unique([usuarioId, nome, tipo])
  @@index([usuarioId])
  @@index([tipo])
  @@map("categorias")
}

// ==========================================
// TRANSAÇÕES
// ==========================================

model Transacao {
  id               String        @id @default(cuid())
  usuarioId        String        @map("usuario_id")
  categoriaId      String        @map("categoria_id")
  tipo             TipoTransacao
  recurso          TipoRecurso
  valor            Decimal       @db.Decimal(12, 2)
  descricao        String?       @db.VarChar(255)
  data             DateTime
  recorrente       Boolean       @default(false)
  regraRecorrencia String?       @map("regra_recorrencia") // RFC 5545 (RRULE)
  paiId            String?       @map("pai_id") // referência à transação "mãe" recorrente
  criadoEm         DateTime      @default(now()) @map("criado_em")
  atualizadoEm     DateTime      @updatedAt @map("atualizado_em")

  usuario   Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria Categoria      @relation(fields: [categoriaId], references: [id])
  pai       Transacao?     @relation("TransacoesFilhas", fields: [paiId], references: [id], onDelete: SetNull)
  filhas    Transacao[]    @relation("TransacoesFilhas")
  tags      TransacaoTag[]

  @@index([usuarioId, data(sort: Desc)])
  @@index([usuarioId, categoriaId])
  @@index([usuarioId, tipo])
  @@index([usuarioId, recurso])
  @@index([usuarioId, recorrente])
  @@map("transacoes")
}

// ==========================================
// TAGS
// ==========================================

model Tag {
  id        String  @id @default(cuid())
  nome      String  @db.VarChar(40)
  icone     String? @db.VarChar(40) // nome Lucide (ex: Tag, Laptop) — PulsoBadge
  cor       String  @default("#71717A") @db.VarChar(7) // hex #RRGGBB
  usuarioId String  @map("usuario_id")

  usuario    Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  transacoes TransacaoTag[]

  @@unique([usuarioId, nome])
  @@index([usuarioId])
  @@map("tags")
}

model TransacaoTag {
  transacaoId String @map("transacao_id")
  tagId       String @map("tag_id")

  transacao Transacao @relation(fields: [transacaoId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transacaoId, tagId])
  @@index([tagId])
  @@map("transacoes_tags")
}

// ==========================================
// METAS
// ==========================================

model Meta {
  id           String     @id @default(cuid())
  usuarioId    String     @map("usuario_id")
  nome         String     @db.VarChar(100)
  valorAlvo    Decimal    @db.Decimal(12, 2) @map("valor_alvo")
  valorAtual   Decimal    @default(0) @db.Decimal(12, 2) @map("valor_atual")
  prazo        DateTime
  tipo         TipoMeta
  status       StatusMeta @default(ATIVA)
  prioridade   Prioridade?
  descricao    String?    @db.VarChar(500)
  concluidaEm  DateTime?  @map("concluida_em")
  criadoEm     DateTime   @default(now()) @map("criado_em")
  atualizadoEm DateTime   @updatedAt @map("atualizado_em")

  usuario Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  aportes AporteMeta[]
  viagens Viagem[]

  @@index([usuarioId, status])
  @@index([usuarioId, prazo])
  @@map("metas")
}

model AporteMeta {
  id       String   @id @default(cuid())
  metaId   String   @map("meta_id")
  valor    Decimal  @db.Decimal(12, 2)
  data     DateTime
  criadoEm DateTime @default(now()) @map("criado_em")

  meta Meta @relation(fields: [metaId], references: [id], onDelete: Cascade)

  @@index([metaId, data(sort: Desc)])
  @@map("aportes_meta")
}

// ==========================================
// VIAGENS
// ==========================================

model Viagem {
  id           String   @id @default(cuid())
  usuarioId    String   @map("usuario_id")
  destino      String   @db.VarChar(120)
  moeda        String   @db.VarChar(3)
  dataPrevista DateTime @map("data_prevista")
  metaId       String?  @map("meta_id")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  usuario  Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  meta     Meta?           @relation(fields: [metaId], references: [id], onDelete: SetNull)
  despesas DespesaViagem[]

  @@index([usuarioId, dataPrevista])
  @@map("viagens")
}

model DespesaViagem {
  id            String                 @id @default(cuid())
  viagemId      String                 @map("viagem_id")
  categoria     CategoriaDespesaViagem
  categoriaId   String?                @map("categoria_id")
  descricao     String?                @db.VarChar(255)
  valorEstimado Decimal                @db.Decimal(12, 2) @map("valor_estimado")
  criadoEm      DateTime               @default(now()) @map("criado_em")

  viagem             Viagem     @relation(fields: [viagemId], references: [id], onDelete: Cascade)
  categoriaVinculada Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  @@index([viagemId])
  @@map("despesas_viagem")
}

// ==========================================
// MOEDAS FAVORITAS
// ==========================================

model MoedaFavorita {
  id        String   @id @default(cuid())
  usuarioId String   @map("usuario_id")
  codigo    String   @db.VarChar(3) // USD, EUR, ARS...
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, codigo])
  @@index([usuarioId])
  @@map("moedas_favoritas")
}

// ==========================================
// LEMBRETES
// ==========================================

model Lembrete {
  id             String               @id @default(cuid())
  usuarioId      String               @map("usuario_id")
  titulo         String               @db.VarChar(120)
  valor          Decimal?             @db.Decimal(12, 2)
  dataVencimento DateTime             @map("data_vencimento")
  antecedencia   AntecedenciaLembrete @default(UM_DIA)
  googleEventId  String?              @map("google_event_id")
  sincronizado   Boolean              @default(false)
  criadoEm       DateTime             @default(now()) @map("criado_em")
  atualizadoEm   DateTime             @updatedAt @map("atualizado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, dataVencimento])
  @@index([sincronizado])
  @@map("lembretes")
}

// ==========================================
// VALE TRANSPORTE
// ==========================================

model VendaVt {
  id               String    @id @default(cuid())
  usuarioId        String    @map("usuario_id")
  nomeComprador    String    @db.VarChar(120) @map("nome_comprador")
  dataVenda        DateTime  @map("data_venda")
  valorNominal     Decimal   @db.Decimal(12, 2) @map("valor_nominal")
  valorRecebido    Decimal   @db.Decimal(12, 2) @map("valor_recebido")
  proximaDataVenda DateTime? @map("proxima_data_venda")
  criadoEm         DateTime  @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, dataVenda(sort: Desc)])
  @@map("vendas_vt")
}

model UsoVt {
  id               String   @id @default(cuid())
  usuarioId        String   @map("usuario_id")
  quantidade       Int
  valorPorPassagem Decimal  @db.Decimal(10, 2) @map("valor_por_passagem")
  data             DateTime
  criadoEm         DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, data(sort: Desc)])
  @@map("usos_vt")
}

// ==========================================
// GAMIFICAÇÃO
// ==========================================

model Sequencia {
  id              String          @id @default(cuid())
  usuarioId       String          @unique @map("usuario_id")
  sequenciaAtual  Int             @default(0) @map("sequencia_atual")
  maiorSequencia  Int             @default(0) @map("maior_sequencia")
  xp              Int             @default(0)
  nivel           NivelFinanceiro @default(INICIANTE)
  ultimaAtividade DateTime?       @map("ultima_atividade")
  atualizadoEm    DateTime        @updatedAt @map("atualizado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sequencias")
}

model Conquista {
  id           String @id @default(cuid())
  codigo       String @unique @db.VarChar(60) // identificador técnico (ex: PRIMEIRA_META)
  nome         String @db.VarChar(100)
  descricao    String @db.VarChar(255)
  icone        String @db.VarChar(40)
  criterio     Json // regras estruturadas
  recompensaXp Int    @default(0) @map("recompensa_xp")

  conquistasUsuario ConquistaUsuario[]

  @@map("conquistas")
}

model ConquistaUsuario {
  id             String   @id @default(cuid())
  usuarioId      String   @map("usuario_id")
  conquistaId    String   @map("conquista_id")
  desbloqueadaEm DateTime @default(now()) @map("desbloqueada_em")

  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  conquista Conquista @relation(fields: [conquistaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, conquistaId])
  @@index([usuarioId])
  @@map("conquistas_usuario")
}

model DesafioMensal {
  id          String    @id @default(cuid())
  usuarioId   String    @map("usuario_id")
  titulo      String    @db.VarChar(120)
  descricao   String    @db.VarChar(500)
  criterio    Json
  mes         Int // 1-12
  ano         Int
  progresso   Decimal   @default(0) @db.Decimal(5, 2) // 0-100
  concluido   Boolean   @default(false)
  concluidoEm DateTime? @map("concluido_em")
  criadoEm    DateTime  @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, mes, ano])
  @@index([usuarioId])
  @@map("desafios_mensais")
}

// ==========================================
// IA / CHATBOT
// ==========================================

model MensagemChat {
  id        String   @id @default(cuid())
  usuarioId String   @map("usuario_id")
  papel     String   @db.VarChar(20) // "user" | "assistant"
  conteudo  String   @db.Text
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, criadoEm(sort: Desc)])
  @@map("mensagens_chat")
}

model HistoricoScore {
  id        String   @id @default(cuid())
  usuarioId String   @map("usuario_id")
  score     Int
  detalhes  Json?
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, criadoEm(sort: Desc)])
  @@map("historico_score")
}

// ==========================================
// GRUPOS
// ==========================================

model Grupo {
  id            String   @id @default(cuid())
  nome          String   @db.VarChar(100)
  descricao     String?  @db.VarChar(500)
  codigoConvite String   @unique @map("codigo_convite")
  criadorId     String   @map("criador_id")
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  criador   Usuario             @relation("CriadorGrupo", fields: [criadorId], references: [id], onDelete: Cascade)
  membros   MembroGrupo[]
  viagens   ViagemGrupo[]
  metas     MetaGrupo[]
  mensagens MensagemChatGrupo[]

  @@index([criadorId])
  @@map("grupos")
}

model MembroGrupo {
  id        String     @id @default(cuid())
  grupoId   String     @map("grupo_id")
  usuarioId String     @map("usuario_id")
  papel     PapelGrupo @default(MEMBRO)
  entrouEm  DateTime   @default(now()) @map("entrou_em")

  grupo   Grupo   @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([grupoId, usuarioId])
  @@index([usuarioId])
  @@map("membros_grupo")
}

model ViagemGrupo {
  id           String   @id @default(cuid())
  grupoId      String   @map("grupo_id")
  destino      String   @db.VarChar(120)
  moeda        String   @db.VarChar(3)
  dataPrevista DateTime @map("data_prevista")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  grupo    Grupo                @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  despesas DespesaViagemGrupo[]

  @@index([grupoId])
  @@map("viagens_grupo")
}

model DespesaViagemGrupo {
  id              String                 @id @default(cuid())
  viagemGrupoId   String                 @map("viagem_grupo_id")
  adicionadoPorId String                 @map("adicionado_por_id")
  categoria       CategoriaDespesaViagem
  descricao       String?                @db.VarChar(255)
  valorEstimado   Decimal                @db.Decimal(12, 2) @map("valor_estimado")
  criadoEm        DateTime               @default(now()) @map("criado_em")

  viagem        ViagemGrupo @relation(fields: [viagemGrupoId], references: [id], onDelete: Cascade)
  adicionadoPor Usuario     @relation(fields: [adicionadoPorId], references: [id], onDelete: Cascade)

  @@index([viagemGrupoId])
  @@map("despesas_viagem_grupo")
}

model MetaGrupo {
  id           String     @id @default(cuid())
  grupoId      String     @map("grupo_id")
  nome         String     @db.VarChar(100)
  valorAlvo    Decimal    @db.Decimal(12, 2) @map("valor_alvo")
  valorAtual   Decimal    @default(0) @db.Decimal(12, 2) @map("valor_atual")
  prazo        DateTime
  status       StatusMeta @default(ATIVA)
  descricao    String?    @db.VarChar(500)
  criadoEm     DateTime   @default(now()) @map("criado_em")
  atualizadoEm DateTime   @updatedAt @map("atualizado_em")

  grupo   Grupo             @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  aportes AporteMetaGrupo[]

  @@index([grupoId, status])
  @@map("metas_grupo")
}

model AporteMetaGrupo {
  id          String   @id @default(cuid())
  metaGrupoId String   @map("meta_grupo_id")
  usuarioId   String   @map("usuario_id")
  valor       Decimal  @db.Decimal(12, 2)
  data        DateTime
  criadoEm    DateTime @default(now()) @map("criado_em")

  meta    MetaGrupo @relation(fields: [metaGrupoId], references: [id], onDelete: Cascade)
  usuario Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([metaGrupoId, data(sort: Desc)])
  @@index([usuarioId])
  @@map("aportes_meta_grupo")
}

model MensagemChatGrupo {
  id        String   @id @default(cuid())
  grupoId   String   @map("grupo_id")
  usuarioId String   @map("usuario_id")
  conteudo  String   @db.Text
  criadoEm  DateTime @default(now()) @map("criado_em")

  grupo   Grupo   @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([grupoId, criadoEm(sort: Desc)])
  @@map("mensagens_chat_grupo")
}
