# ========================================
# 🔧 SERVIDOR
# ========================================
PORT=3333
NODE_ENV=development

# ========================================
# 🗄️ BANCO DE DADOS (Neon)
# ========================================
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DIRECT_URL=postgresql://user:password@host/database?sslmode=require

# ========================================
# 🔑 JWT
# ========================================
JWT_SECRET=sua_chave_secreta_aqui
JWT_REFRESH_SECRET=sua_chave_refresh_aqui

# ========================================
# 🔐 GOOGLE OAUTH
# ========================================
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3333/api/auth/google/callback

# ========================================
# 🤖 GOOGLE GEMINI (IA)
# ========================================
GEMINI_API_KEY=sua_api_key_aqui

# ========================================
# 📧 EMAIL (SMTP) — Mailtrap
# ========================================
# Guia rápido:
#   • SANDBOX (dev): emails NÃO chegam no Gmail — ficam na inbox do Mailtrap
#     mailtrap.io → Email Testing → Sandboxes → Integration → SMTP
#   • SENDING (real): emails chegam de verdade — precisa domínio verificado
#     mailtrap.io → Sending Domains → Integration → SMTP (Transactional)
#
# --- Opção A: SANDBOX (desenvolvimento) ---
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=seu_username_do_sandbox
# SMTP_PASS=sua_password_do_sandbox
# SMTP_FROM=nao-responda@pulso.dev
#
# --- Opção B: ENVIO REAL (produção / teste no Gmail) ---
# SMTP_HOST=live.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=api
# SMTP_PASS=seu_api_token_do_mailtrap
# SMTP_FROM=noreply@seudominio.com
#
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=seu_username_sandbox
SMTP_PASS=sua_password_sandbox
SMTP_FROM=Pulso <nao-responda@seudominio.com>

# ========================================
# 🌐 CORS
# ========================================
CORS_ORIGIN=http://localhost:5173

# ========================================
# 🔗 FRONTEND URL (usado em links de email)
# ========================================
FRONTEND_URL=http://localhost:5173