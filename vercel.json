{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "build": {
    "env": {
      "VITE_API_URL": "/api"
    }
  },
  "outputDirectory": "Codigo/Pulso/web/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 10,
      "includeFiles": "Codigo/Pulso/api/node_modules/.prisma/client/**",
      "excludeFiles": "{Codigo/Pulso/api/{tests,Documents,scripts,prisma/migrations}/**,Codigo/Pulso/web/**}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "5 0 * * *"
    }
  ]
}
