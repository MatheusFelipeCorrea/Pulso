{
  "name": "pulso",
  "private": true,
  "description": "Pulso — deploy unificado Vercel (web + API)",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "postinstall": "npm install --omit=dev --prefix Codigo/Pulso/api && npm install --include=dev --prefix Codigo/Pulso/web",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm run build --prefix Codigo/Pulso/web",
    "build:api": "npm run db:generate --prefix Codigo/Pulso/api",
    "dev:web": "npm run dev --prefix Codigo/Pulso/web",
    "dev:api": "npm run dev --prefix Codigo/Pulso/api"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "serverless-http": "^3.2.0"
  }
}
